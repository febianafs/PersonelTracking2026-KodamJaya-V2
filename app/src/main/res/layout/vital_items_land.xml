<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/cardVitalSigns"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/background"
            tools:ignore="MissingConstraints">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- KONTEN UTAMA -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <!-- DEVICE NAME (paling atas) -->
                    <TextView
                        android:id="@+id/tvDeviceName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Garmin Forerunner 55"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <!-- BLE STATUS -->
                    <TextView
                        android:id="@+id/tvBleStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Connected"
                        android:textColor="#4FC3F7"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvDeviceName"/>

                    <!-- HEART RATE -->
                    <TextView
                        android:id="@+id/tvHeartRate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="87 BPM"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvBleStatus"/>

<!--                    &lt;!&ndash; BPM CATEGORY &ndash;&gt;-->
<!--                    <TextView-->
<!--                        android:id="@+id/tvBpmCategory"-->
<!--                        android:layout_width="wrap_content"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:text="normal"-->
<!--                        android:textColor="#69F0AE"-->
<!--                        android:textSize="10sp"-->
<!--                        android:layout_marginTop="2dp"-->
<!--                        app:layout_constraintStart_toStartOf="parent"-->
<!--                        app:layout_constraintTop_toBottomOf="@id/tvHeartRate"/>-->

                    <!-- BLE SETTINGS pojok kanan bawah -->
                    <TextView
                        android:id="@+id/btnBleSettings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BLE settings ›"
                        android:textColor="#4FC3F7"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- DIVIDER -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1A3A5C"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"/>

                <!-- LAST SYNC ROW -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/iconSync"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_sync"
                        app:tint="#90CAF9"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last sync"
                        android:textColor="#90CAF9"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/tvLastSync"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2 seconds ago"
                        android:textColor="#69F0AE"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:layout_marginStart="6dp"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"/>

                    <View
                        android:id="@+id/dotLastSync"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_dot_connected"/>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>