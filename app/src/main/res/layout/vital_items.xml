<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardVitalSigns"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- DEVICE CARD -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="105dp"
            android:background="#151E27"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDeviceName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:text="Garmin Forerunner 55"
                    android:textColor="#EAF2FF"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tvBleStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:text="Connected"
                    android:textColor="#4FC3F7"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:layout_width="40dp"
                android:layout_height="20dp"
                android:layout_gravity="top|end"
                android:gravity="center"
                android:text="BLE"
                android:textColor="#69F0AE"
                android:textSize="9sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- BPM CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:background="#151E27"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvHeartRate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="87"
                android:textColor="#4FC3F7"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="BPM"
                android:textColor="#AAB4C0"
                android:textSize="12sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/btnBleSettings"
            android:layout_width="120dp"
            android:layout_height="42dp"
            android:layout_gravity="end"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="BLE settings >"
            android:textColor="#4FC3F7"
            android:textSize="13sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A3A5C" />

        <!-- LAST SYNC ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iconSync"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginEnd="6dp"
                android:src="@drawable/ic_sync"
                app:tint="#90CAF9" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last sync"
                android:textColor="#90CAF9"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvLastSync"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="2 seconds ago"
                android:textColor="#69F0AE"
                android:textSize="11sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <View
                android:id="@+id/dotLastSync"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot_connected" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>